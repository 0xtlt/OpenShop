{
  "name": "openshop",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:cli": "node scripts/build-cli.mjs",
    "prepack": "npm run build:cli",
    "test": "bun tests/bootstrap.ts",
    "test:integration": "bun tests/bootstrap-integration.ts"
  },
  "bin": {
    "openshop": "./bin/cli.js"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "templates",
    "prisma",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./vite": "./src/vite/codegen-plugin.ts",
    "./test": "./src/test/index.ts",
    "./schema": "./src/db/schema.ts",
    "./drizzle": "./src/db/drizzle-config.ts",
    "./eslint": "./src/eslint/config.ts",
    "./graphql": "./src/graphql/config.ts"
  },
  "imports": {
    "#db/*": "./src/db/*",
    "#engine/*": "./src/engine/*",
    "#server/*": "./src/server/*",
    "#shopify/*": "./src/shopify/*",
    "#types": "./src/types.ts"
  },
  "dependencies": {
    "@hono/node-server": "2.0.1",
    "arktype": "^2.2.0",
    "croner": "^10.0.0",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.16",
    "pg": "^8.20.0"
  },
  "peerDependencies": {
    "eslint": ">=9",
    "@graphql-eslint/eslint-plugin": ">=4",
    "typescript-eslint": ">=8"
  },
  "devDependencies": {
    "@japa/api-client": "3",
    "@japa/assert": "4",
    "@japa/runner": "5",
    "@preact/preset-vite": "2.10.5",
    "@shopify/polaris-types": "^1.0.1",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "0.28.0",
    "eslint": "10.3.0",
    "preact": "^10.29.0",
    "preact-iso": "^2.9.0",
    "ts-cron-validator": "^1.1.5",
    "typescript": "^5.9.0",
    "vite": "8.0.10"
  }
}
